{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "muesly",
    "version": "0.1.0",
    "identifier": "com.muesly",
    "build": {
        "frontendDist": "../src-svelte/build",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "nub --cwd src-svelte run dev",
        "beforeBuildCommand": "nub --cwd src-svelte run build:tauri"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "muesly",
                "width": 1100,
                "height": 700,
                "resizable": true,
                "fullscreen": false,
                "theme": "Light",
                "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
            {
                "label": "pill",
                "url": "/pill",
                "width": 72,
                "height": 184,
                "resizable": false,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "shadow": false,
                "focus": false,
                "acceptFirstMouse": true,
                "visible": false,
                "backgroundThrottling": "disabled",
                "title": "muesly recording"
            }
        ],
        "macOSPrivateApi": true,
        "security": {
            "csp": {
                "default-src": "'self'",
                "style-src": "'self' 'unsafe-inline'",
                "img-src": "'self' asset: https://asset.localhost data:",
                "connect-src": "'self' http://localhost:11434 https://api.ollama.ai https://api.muesly.ai"
            },
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "$APPDATA/**"
                ]
            },
            "capabilities": [
                {
                    "identifier": "main",
                    "description": "Main window capability with file system and media access",
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "fs:default",
                        "fs:allow-read-file",
                        "fs:allow-app-read",
                        "fs:allow-app-write",
                        "fs:allow-download-write",
                        "fs:allow-download-read",
                        "fs:scope-download",
                        "core:path:default",
                        "core:event:default",
                        "core:window:default",
                        "core:app:default",
                        "core:resources:default",
                        "core:menu:default",
                        "core:tray:default",
                        "core:window:allow-set-title",
                        "core:window:allow-start-dragging",
                        "core:window:allow-internal-toggle-maximize",
                        "store:default",
                        "notification:default",
                        "notification:allow-is-permission-granted",
                        "updater:default",
                        "process:default",
                        {
                            "identifier": "fs:scope",
                            "allow": [
                                {
                                    "path": "$APPDATA/*"
                                }
                            ]
                        }
                    ]
                },
                {
                    "identifier": "pill",
                    "description": "Floating recording pill window",
                    "windows": [
                        "pill"
                    ],
                    "permissions": [
                        "core:event:default",
                        "core:window:default",
                        "core:window:allow-start-dragging",
                        "core:path:default"
                    ]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "deb",
            "appimage",
            "msi",
            "nsis",
            "app",
            "dmg"
        ],
        "createUpdaterArtifacts": true,
        "icon": [
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [
            "templates/*.json"
        ],
        "externalBin": [
            "binaries/llama-helper",
            "binaries/diarization-helper",
            "binaries/ffmpeg"
        ],
        "macOS": {
            "entitlements": "entitlements.plist",
            "signingIdentity": "-",
            "hardenedRuntime": true
        },
        "windows": {
            "signCommand": "powershell -ExecutionPolicy Bypass -File ../scripts/sign-windows.ps1 -FilePath %1"
        }
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBMzY2NkY0RTI1QTRGNUIKUldSYlQxcmk5R1kycWpqYlE3WUFEYmo2V0lQTFU0NDZUSC9Hai9kQUFSeWhiNHBnZTRlMk1lZjQK",
            "endpoints": [
                "https://github.com/afonsojramos/muesly/releases/latest/download/latest.json"
            ]
        }
    }
}
