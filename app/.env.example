# Tauri Code Signing Configuration

TAURI_SIGNING_PRIVATE_KEY=

TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Notes:
# - The key should be a single line of base64-encoded text
# - The password is used by Tauri during the signing process
# - Both values are loaded as environment variables during build
# - For CI/CD, set these as repository secrets instead of using .env

# PostHog Analytics (optional)

# Project API key (phc_...): the PUBLIC ingest key that sends events + errors.
# Baked into release builds from the CI secret; set here to enable analytics in
# local dev (loaded at runtime via dotenvy).
POSTHOG_API_KEY=

# Sourcemap upload — makes frontend error-tracking stacks readable. Used by
# `posthog-cli sourcemap process` during the build. In practice CI-only: the
# personal key is a real secret, prefer repository secrets over .env.
#
# POSTHOG_CLI_TOKEN: a PERSONAL API key (phx_...) with error-tracking write scope
#   (Settings -> Personal API keys). NOT the phc_ ingest key above.
# POSTHOG_CLI_ENV_ID: the project id (the number in the project URL).
# POSTHOG_CLI_HOST: ingestion host (this project is on EU).
POSTHOG_CLI_TOKEN=
POSTHOG_CLI_ENV_ID=
POSTHOG_CLI_HOST=https://eu.posthog.com
