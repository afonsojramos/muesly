---
import { meeting, transcript } from '$lib/components/product/mock-data';
---

<div
	role="img"
	aria-label="muesly recording a meeting, showing notes on the left and a live transcript streaming on the right"
	class="overflow-hidden rounded-2xl border border-border bg-card shadow-lg"
>
	<!-- Window bar -->
	<div class="flex items-center gap-2 border-b border-border bg-secondary/40 px-4 py-2.5">
		<span class="h-3 w-3 rounded-full bg-destructive/50"></span>
		<span class="h-3 w-3 rounded-full bg-warning/60"></span>
		<span class="h-3 w-3 rounded-full bg-success/60"></span>
		<span class="ml-3 truncate text-sm font-medium text-muted-foreground">{meeting.title}</span>
		<div class="ml-auto flex items-center gap-2">
			<span class="relative flex h-2.5 w-2.5">
				<span
					class="absolute inline-flex h-full w-full rounded-full bg-accent opacity-60 motion-safe:animate-ping"
				></span>
				<span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-accent"></span>
			</span>
			<span class="text-xs font-medium text-muted-foreground tabular-nums">12:48</span>
		</div>
	</div>

	<!-- Body: notes + live transcript -->
	<div class="grid gap-px bg-border sm:grid-cols-[1.2fr_1fr]">
		<div class="bg-card p-5">
			<div class="text-xs font-medium tracking-wide text-muted-foreground uppercase">Notes</div>
			<div class="mt-3 space-y-2 text-sm">
				<p class="font-display text-base font-semibold">{meeting.title}</p>
				<p class="text-muted-foreground">Launch on the 14th — v1 is core capture.</p>
				<p class="text-muted-foreground">Import deferred by one week.</p>
				<span
					class="inline-block h-4 w-px bg-accent align-middle motion-safe:animate-pulse"
					aria-hidden="true"></span>
			</div>
		</div>

		<div class="bg-card p-5">
			<div class="flex items-center justify-between">
				<div class="text-xs font-medium tracking-wide text-muted-foreground uppercase">
					Live transcript
				</div>
				<div class="flex h-4 items-end gap-0.5" aria-hidden="true">
					<span class="rec-bar h-full w-1 rounded-full bg-accent"></span>
					<span class="rec-bar h-full w-1 rounded-full bg-accent"></span>
					<span class="rec-bar h-full w-1 rounded-full bg-accent"></span>
				</div>
			</div>
			<ul class="mt-3 space-y-2.5">
				{
					transcript.map((seg) => (
						<li class="text-sm">
							<span class="text-xs font-medium text-muted-foreground tabular-nums">{seg.time}</span>
							<span class="ml-1 text-xs font-medium text-accent">{seg.speaker}</span>
							<p class="text-muted-foreground">{seg.text}</p>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</div>
