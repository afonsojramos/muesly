---
import { Icon } from 'astro-icon/components';

interface Props {
	competitor?: string;
}

const { competitor = 'Cloud assistant' } = Astro.props;
---

<figure aria-label={`How muesly's local data path compares with ${competitor}'s cloud data path`}>
	<div class="rounded-[20px] bg-card p-3 shadow-card sm:p-4">
		<div class="rounded-xl bg-secondary/55 px-4 py-3 text-center text-xs font-medium text-muted-foreground">
			<Icon
				name="lucide:messages-square"
				class="mr-1.5 inline size-3.5 text-foreground"
				aria-hidden="true"
			/>
			Your conversation
		</div>

		<div class="relative my-2 h-7" aria-hidden="true">
			<div class="absolute top-0 left-1/2 h-3.5 w-px bg-border"></div>
			<div class="absolute top-3.5 right-1/4 left-1/4 h-px bg-border"></div>
			<div class="absolute top-3.5 left-1/4 h-3.5 w-px bg-border"></div>
			<div class="absolute top-3.5 right-1/4 h-3.5 w-px bg-border"></div>
		</div>

		<div class="grid grid-cols-2 gap-2 sm:gap-3">
			<div class="overflow-hidden rounded-xl bg-foreground text-primary-foreground">
				<div class="border-b border-white/10 px-3 py-2.5 text-xs font-semibold sm:px-4">
					<span class="mr-1.5 inline-block size-1.5 rounded-full bg-accent align-middle"></span>
					muesly
				</div>
				<div class="grid gap-2 p-3 sm:p-4">
					<div class="flex min-h-14 items-center gap-2 rounded-lg bg-white/6 px-2.5 text-[11px] text-white/70 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.07)] sm:px-3 sm:text-xs">
						<Icon name="lucide:laptop" class="size-3.5 shrink-0 text-accent" aria-hidden="true" />
						<span>Local transcription + AI</span>
					</div>
					<div class="flex items-center justify-center text-white/25" aria-hidden="true">
						<Icon name="lucide:arrow-down" class="size-3.5" />
					</div>
					<div class="flex min-h-14 items-center gap-2 rounded-lg bg-white/6 px-2.5 text-[11px] text-white/70 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.07)] sm:px-3 sm:text-xs">
						<Icon name="lucide:database" class="size-3.5 shrink-0 text-accent" aria-hidden="true" />
						<span>Database on your device</span>
					</div>
				</div>
			</div>

			<div class="overflow-hidden rounded-xl bg-secondary/65">
				<div class="border-b border-border px-3 py-2.5 text-xs font-semibold text-muted-foreground sm:px-4">
					<span
						class="mr-1.5 inline-block size-1.5 rounded-full bg-muted-foreground/45 align-middle"></span>
					{competitor}
				</div>
				<div class="grid gap-2 p-3 sm:p-4">
					<div class="flex min-h-14 items-center gap-2 rounded-lg bg-card px-2.5 text-[11px] text-muted-foreground shadow-card sm:px-3 sm:text-xs">
						<Icon name="lucide:cloud" class="size-3.5 shrink-0" aria-hidden="true" />
						<span>Vendor cloud processing</span>
					</div>
					<div class="flex items-center justify-center text-muted-foreground/35" aria-hidden="true">
						<Icon name="lucide:arrow-down" class="size-3.5" />
					</div>
					<div class="flex min-h-14 items-center gap-2 rounded-lg bg-card px-2.5 text-[11px] text-muted-foreground shadow-card sm:px-3 sm:text-xs">
						<Icon name="lucide:server" class="size-3.5 shrink-0" aria-hidden="true" />
						<span>Account-based cloud history</span>
					</div>
				</div>
			</div>
		</div>
	</div>
	<figcaption class="mt-3 text-center text-xs text-muted-foreground">
		The key difference is where processing and long-term memory live.
	</figcaption>
</figure>
