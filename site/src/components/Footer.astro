---
import { GITHUB_URL, LICENSE_URL, RELEASES_PAGE } from '$lib/config';
import MueslyMark from './MueslyMark.astro';

const ext = { target: '_blank', rel: 'noopener noreferrer' };
---

<footer class="border-t border-border">
	<div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 sm:grid-cols-2 md:grid-cols-[1.5fr_1fr_1fr]">
		<div>
			<a href="/" class="flex items-center gap-2" aria-label="muesly home">
				<MueslyMark class="h-7 w-7" />
				<span class="font-display text-lg font-semibold tracking-tight">muesly</span>
			</a>
			<p class="mt-3 max-w-xs text-sm text-muted-foreground">
				Private, on-device meeting notes. Privacy-first. Local. Open source.
			</p>
		</div>

		<nav aria-label="Product" class="text-sm">
			<h2 class="mb-3 font-medium text-foreground">Product</h2>
			<ul class="space-y-2 text-muted-foreground">
				<li><a class="hover:text-foreground" href="/download">Download</a></li>
				<li><a class="hover:text-foreground" href="/privacy">Privacy</a></li>
			</ul>
		</nav>

		<nav aria-label="Project" class="text-sm">
			<h2 class="mb-3 font-medium text-foreground">Project</h2>
			<ul class="space-y-2 text-muted-foreground">
				<li><a class="hover:text-foreground" href={GITHUB_URL} {...ext}>GitHub</a></li>
				<li><a class="hover:text-foreground" href={RELEASES_PAGE} {...ext}>Releases</a></li>
				<li><a class="hover:text-foreground" href={LICENSE_URL} {...ext}>License (MIT)</a></li>
			</ul>
		</nav>
	</div>

	<div class="mx-auto max-w-6xl px-6 pb-10 text-sm text-muted-foreground">
		Free and open source. Available for macOS, Windows, and Linux.
	</div>
</footer>
