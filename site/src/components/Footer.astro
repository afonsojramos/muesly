---
import MueslyMark from './MueslyMark.astro';
---

<footer class="bg-foreground text-primary-foreground">
	<div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 sm:grid-cols-2 sm:px-6 md:grid-cols-[1.5fr_1fr_1fr]">
		<div>
			<a href="/" class="flex items-center gap-2" aria-label="muesly home">
				<MueslyMark class="h-7 w-7" />
				<span class="font-display text-lg font-semibold tracking-tight">muesly</span>
			</a>
			<p class="mt-3 max-w-xs text-sm leading-relaxed text-white/50">
				Private speech-to-text for meetings, calls, lectures, and everything you say.
			</p>
		</div>

		<nav aria-label="Product" class="text-sm">
			<h2 class="mb-3 font-medium text-white">Product</h2>
			<ul class="space-y-2 text-white/50">
				<li><a class="transition-colors hover:text-white" href="/download">Download</a></li>
				<li><a class="transition-colors hover:text-white" href="/compare">Compare</a></li>
				<li><a class="transition-colors hover:text-white" href="/#features">Features</a></li>
				<li><a class="transition-colors hover:text-white" href="/#faq">FAQ</a></li>
				<li><a class="transition-colors hover:text-white" href="/privacy">Privacy</a></li>
				<li><a class="transition-colors hover:text-white" href="/terms">Terms</a></li>
			</ul>
		</nav>

		<nav aria-label="Legal" class="text-sm">
			<h2 class="mb-3 font-medium text-white">Legal</h2>
			<ul class="space-y-2 text-white/50">
				<li><a class="transition-colors hover:text-white" href="/privacy">Privacy policy</a></li>
				<li><a class="transition-colors hover:text-white" href="/terms">Terms & license</a></li>
			</ul>
		</nav>
	</div>

	<div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-3 px-5 pb-10 text-sm text-white/40 sm:px-6">
		<span>Free for personal and noncommercial use. Available for macOS, Windows, and Linux.</span>
		<span>Made to keep your conversations yours.</span>
	</div>
</footer>
