---
import Section from '../ui/Section.astro';

// Answers double as objection-handling and FAQPage structured data (below).
// Keep every answer accurate against PRIVACY_POLICY.md (analytics is opt-in,
// cloud LLM is opt-in).
const faqs = [
	{
		q: 'Is muesly really free?',
		a: 'Yes. muesly is free for personal and noncommercial use under the PolyForm Noncommercial license. There is no paid tier and no account. Commercial use requires a separate license.'
	},
	{
		q: 'Where does my data go?',
		a: 'Recordings, transcripts, and summaries are processed and stored on your device. Nothing is uploaded unless you explicitly configure a cloud LLM provider for summaries.'
	},
	{
		q: 'Does it need an internet connection?',
		a: 'Core recording, transcription, local summaries, search, and storage work on your device. An internet connection is only needed for downloads, optional cloud summary providers, and optional anonymous analytics.'
	},
	{
		q: 'Does it work with Zoom, Teams, and Google Meet?',
		a: 'Yes. muesly captures system audio alongside your microphone, so it works with any call. No bot joins the meeting.'
	},
	{
		q: 'Is there a meeting bot?',
		a: 'No. muesly records locally from your own audio. Nothing joins your call and no participant sees a recorder.'
	},
	{
		q: 'Do I need an account?',
		a: 'No account, no sign-up, no email. Download and run.'
	},
	{
		q: 'What analytics does muesly collect?',
		a: 'Optional anonymized usage analytics helps fix bugs and improve performance. It is off by default, never includes meeting content, and can be enabled or disabled in settings. Builds compiled without an analytics key have it off entirely.'
	},
	{
		q: 'Which platforms are supported?',
		a: 'Native downloads are available for Apple Silicon macOS, x64 Windows, and x64 Linux as an AppImage or .deb package.'
	}
];

const faqSchema = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a }
	}))
});
---

<Section id="faq" class="py-16 md:py-20">
	<div class="mx-auto max-w-2xl text-center" data-reveal>
		<h2 class="font-display text-3xl font-semibold tracking-tight md:text-4xl">Questions, answered</h2>
	</div>

	<dl class="mx-auto mt-10 max-w-2xl divide-y divide-border" data-reveal>
		{
			faqs.map((faq) => (
				<div class="py-5">
					<dt class="font-medium text-foreground">{faq.q}</dt>
					<dd class="mt-2 text-sm text-muted-foreground">{faq.a}</dd>
				</div>
			))
		}
	</dl>
</Section>

<script type="application/ld+json" set:html={faqSchema} is:inline />
