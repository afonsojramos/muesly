---
import { Icon } from 'astro-icon/components';
import Section from '../ui/Section.astro';

const items = [
	{ icon: 'lucide:badge-check', label: 'Open source (MIT)' },
	{ icon: 'lucide:shield-check', label: 'No account required' },
	{ icon: 'lucide:hard-drive', label: 'On-device by default' }
];
---

<Section class="py-6">
	<ul
		class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-medium text-muted-foreground"
	>
		{
			items.map((item) => (
				<li class="flex items-center gap-2">
					<Icon name={item.icon} class="h-4 w-4 text-accent" aria-hidden="true" />
					{item.label}
				</li>
			))
		}
	</ul>
</Section>
