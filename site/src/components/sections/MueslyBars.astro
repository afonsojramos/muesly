---
import { Icon } from 'astro-icon/components';
import Section from '../ui/Section.astro';

// A representative slice of the built-in catalog, one per meeting-lifecycle
// scenario so the range is clear at a glance.
const bars = [
	{
		icon: 'lucide:calendar',
		title: 'Prep my day',
		body: 'A quick brief on what is coming up, drawn from past meetings.',
		scenario: 'Before a meeting'
	},
	{
		icon: 'lucide:circle-help',
		title: 'What did I miss?',
		body: 'Catch up on the last few minutes without breaking your focus.',
		scenario: 'During a meeting'
	},
	{
		icon: 'lucide:scroll-text',
		title: 'Summarize',
		body: 'A concise recap the moment the call ends.',
		scenario: 'After a meeting'
	},
	{
		icon: 'lucide:list-checks',
		title: 'Action items',
		body: 'To-dos with owners and due dates, pulled straight from the transcript.',
		scenario: 'After a meeting'
	},
	{
		icon: 'lucide:mail',
		title: 'Follow-up email',
		body: 'A short recap email with next steps, ready to send.',
		scenario: 'After a meeting'
	},
	{
		icon: 'lucide:git-branch',
		title: 'Recent to-dos',
		body: 'Everything still open across all of your recent meetings.',
		scenario: 'Across meetings'
	}
];
---

<Section id="bars" class="py-20 md:py-28">
	<div class="mx-auto max-w-2xl text-center" data-reveal>
		<span
			class="inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1 text-sm font-medium"
		>
			<Icon name="lucide:wheat" class="h-3.5 w-3.5" aria-hidden="true" />
			Muesly bars
		</span>
		<h2 class="mt-4 font-display text-3xl font-semibold tracking-tight md:text-4xl">
			Reusable prompts, built into the chat
		</h2>
		<p class="mt-3 text-muted-foreground leading-relaxed">
			Muesly bars are one-tap prompts you run over a single meeting or across all of them, before,
			during, and after the call. Use the built-ins, browse popular community recipes, import a bar,
			or write your own.
		</p>
	</div>

	<div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-reveal>
		{
			bars.map((bar) => (
				<div class="rounded-2xl bg-card p-6 shadow-card transition-[transform,box-shadow] duration-200 ease-out hover:-translate-y-0.5 hover:shadow-card-hover">
					<div class="flex items-center justify-between gap-3">
						<span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent">
							<Icon name={bar.icon} class="h-5 w-5" aria-hidden="true" />
						</span>
						<span class="text-xs text-muted-foreground">{bar.scenario}</span>
					</div>
					<h3 class="mt-4 text-lg font-semibold">{bar.title}</h3>
					<p class="mt-1.5 text-sm text-muted-foreground">{bar.body}</p>
					<div class="mt-4 flex items-center gap-1.5 text-[11px] text-muted-foreground">
						<Icon name="lucide:trending-up" class="size-3 text-accent" /> Popular with the community
					</div>
				</div>
			))
		}
	</div>
</Section>
