---
import { cn } from '$lib/utils/cn';

interface Props {
	class?: string;
}
const { class: className } = Astro.props;
---

<span
	class={cn(
		'inline-flex items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1 text-sm font-medium text-foreground',
		className
	)}
>
	<slot />
</span>
