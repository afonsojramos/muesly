---
import { Icon } from 'astro-icon/components';
import { comparisons } from '$lib/comparisons';
import Button from '../../components/ui/Button.astro';
import Section from '../../components/ui/Section.astro';
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
	return comparisons.map((comparison) => ({
		params: { slug: comparison.slug },
		props: { comparison }
	}));
}

const { comparison } = Astro.props;
const { name, title, description, intro, rows, theyreBetter } = comparison;
---

<Base title={title} description={description}>
	<Section class="py-16 md:py-24">
		<div class="mx-auto max-w-2xl text-center">
			<h1 class="font-display text-4xl font-semibold tracking-tight md:text-5xl">
				muesly vs {name}
			</h1>
			<p class="mt-4 text-lg text-muted-foreground">{intro}</p>
		</div>

		<div class="mx-auto mt-12 max-w-3xl overflow-hidden rounded-2xl border border-border">
			<table class="w-full text-sm">
				<thead>
					<tr class="border-b border-border bg-secondary/40 text-left">
						<th class="px-4 py-3"><span class="sr-only">Feature</span></th>
						<th class="px-4 py-3 font-semibold text-accent">muesly</th>
						<th class="px-4 py-3 font-medium text-muted-foreground">{name}</th>
					</tr>
				</thead>
				<tbody>
					{
						rows.map((row) => (
							<tr class="border-b border-border last:border-0">
								<td class="px-4 py-3 text-muted-foreground">{row.dimension}</td>
								<td class="px-4 py-3 font-medium text-foreground">{row.muesly}</td>
								<td class="px-4 py-3 text-muted-foreground">{row.them}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<div class="mx-auto mt-10 max-w-2xl rounded-2xl border border-border bg-card p-6">
			<h2 class="font-semibold">Where {name} is stronger</h2>
			<p class="mt-1 text-sm text-muted-foreground">In the spirit of an honest comparison:</p>
			<ul class="mt-3 space-y-2">
				{
					theyreBetter.map((item) => (
						<li class="flex items-start gap-2 text-sm text-muted-foreground">
							<Icon
								name="lucide:check"
								class="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground"
								aria-hidden="true"
							/>
							{item}
						</li>
					))
				}
			</ul>
			<p class="mt-4 text-sm text-muted-foreground">
				If a polished cloud product with those features matters more than keeping your conversations
				on your device, {name} may be the better fit. If verifiable privacy is the priority, that is exactly
				what muesly is built for.
			</p>
		</div>

		<div class="mx-auto mt-10 flex max-w-2xl flex-wrap justify-center gap-3">
			<Button href="/download" variant="accent" size="lg" data-os-cta>
				<span data-os-cta-label>See all downloads</span>
				<Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
			</Button>
			<Button href="/compare" variant="outline" size="lg">All comparisons</Button>
		</div>

		<p class="mx-auto mt-8 max-w-2xl text-center text-xs text-muted-foreground">
			Comparison based on each product's public positioning and may change over time. Corrections
			welcome on GitHub.
		</p>
	</Section>
</Base>
