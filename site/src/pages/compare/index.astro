---
import { Icon } from 'astro-icon/components';
import { comparisons } from '$lib/comparisons';
import CompareFlow from '../../components/product/CompareFlow.astro';
import Button from '../../components/ui/Button.astro';
import Section from '../../components/ui/Section.astro';
import Base from '../../layouts/Base.astro';

const overviewRows = [
	{ label: 'Default processing', muesly: 'On-device', granola: 'Cloud', otter: 'Cloud', fireflies: 'Cloud' },
	{ label: 'Conversation history', muesly: 'Local database', granola: 'Vendor cloud', otter: 'Vendor cloud', fireflies: 'Vendor cloud' },
	{ label: 'Account required', muesly: 'No', granola: 'Yes', otter: 'Yes', fireflies: 'Yes' },
	{ label: 'Bot-free capture', muesly: 'Yes', granola: 'Yes', otter: 'Available', fireflies: 'Available' },
	{ label: 'Offline transcription + AI', muesly: 'Yes', granola: 'No', otter: 'No', fireflies: 'No' }
];
---

<Base
	title="muesly vs the alternatives"
	description="How muesly compares to cloud meeting assistants like Otter, Granola, and Fireflies: private, local, on-device, and free for personal use."
>
	<Section class="py-16 md:py-24">
		<div class="grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-20">
			<div>
				<div class="inline-flex items-center gap-2 text-sm font-medium text-accent">
					<Icon name="lucide:scale" class="size-3.5" aria-hidden="true" />
					Source-backed comparisons
				</div>
				<h1 class="mt-5 max-w-2xl font-display text-5xl leading-[1.04] font-semibold tracking-[-0.035em] md:text-6xl">
					Your conversations have to live somewhere.
				</h1>
				<p class="mt-6 max-w-xl text-lg leading-relaxed text-muted-foreground">
					Cloud assistants trade a larger trust boundary for effortless sharing and integrations.
					muesly keeps the core path—capture, transcription, AI, and history—on your device.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<Button href="/download" variant="accent" size="lg" class="pl-6 pr-5.5" data-os-cta>
						<span data-os-cta-label>See all downloads</span>
						<Icon name="lucide:arrow-right" class="size-4" aria-hidden="true" />
					</Button>
					<Button href="#overview" variant="outline" size="lg">Compare at a glance</Button>
				</div>
			</div>
			<div data-reveal><CompareFlow /></div>
		</div>

		<div class="mt-24 grid gap-10 lg:grid-cols-[0.42fr_1fr] lg:gap-16">
			<div>
				<div class="text-sm font-medium text-accent">Pick a comparison</div>
				<h2 class="mt-3 font-display text-3xl font-semibold">Which tradeoff are you weighing?</h2>
				<p class="mt-3 text-sm leading-relaxed text-muted-foreground">Each page starts with the decision, then shows the architecture and supporting evidence.</p>
			</div>
			<div class="border-y border-border">
			{
				comparisons.map((comparison) => (
					<a
						href={`/compare/${comparison.slug}`}
						class="group grid min-h-36 items-center gap-4 border-b border-border px-1 py-6 last:border-0 sm:grid-cols-[0.62fr_1fr_auto] sm:px-3"
					>
						<h3 class="font-display text-xl font-semibold">muesly vs {comparison.name}</h3>
						<p class="text-sm leading-relaxed text-muted-foreground">{comparison.verdict}</p>
						<span class="flex size-10 items-center justify-center justify-self-end rounded-full bg-secondary text-accent transition-[background-color,transform] duration-150 ease-out group-hover:translate-x-1 group-hover:bg-accent group-hover:text-white">
							<Icon name="lucide:arrow-right" class="size-4" aria-hidden="true" />
						</span>
					</a>
				))
			}
			</div>
		</div>

		<div id="overview" class="mt-24 scroll-mt-24">
			<div class="max-w-2xl">
				<div class="text-sm font-medium text-accent">At a glance</div>
				<h2 class="mt-3 font-display text-3xl font-semibold md:text-4xl">The five differences that shape everything else.</h2>
				<p class="mt-3 text-muted-foreground">A high-level view. The individual pages include nuance, strengths, and official sources.</p>
			</div>
			<div class="mt-10 hidden overflow-hidden rounded-2xl bg-card shadow-card md:block" data-reveal>
				<table class="w-full text-sm">
					<thead><tr class="border-b border-border bg-secondary/45 text-left"><th class="px-4 py-4"><span class="sr-only">Dimension</span></th><th class="px-4 py-4 font-semibold text-accent">muesly</th><th class="px-4 py-4 font-medium">Granola</th><th class="px-4 py-4 font-medium">Otter</th><th class="px-4 py-4 font-medium">Fireflies</th></tr></thead>
					<tbody>{overviewRows.map((row) => <tr class="border-b border-border last:border-0"><td class="px-4 py-4 font-medium">{row.label}</td><td class="bg-accent/[0.035] px-4 py-4 font-medium text-foreground">{row.muesly}</td><td class="px-4 py-4 text-muted-foreground">{row.granola}</td><td class="px-4 py-4 text-muted-foreground">{row.otter}</td><td class="px-4 py-4 text-muted-foreground">{row.fireflies}</td></tr>)}</tbody>
				</table>
			</div>
			<div class="mt-8 grid gap-8 md:hidden">
				{overviewRows.map((row) => <div class="border-t border-border pt-4"><h3 class="text-sm font-semibold">{row.label}</h3><dl class="mt-3 grid grid-cols-2 gap-x-5 gap-y-3 text-xs"><div><dt class="text-accent">muesly</dt><dd class="mt-0.5 font-medium">{row.muesly}</dd></div><div><dt class="text-muted-foreground">Granola</dt><dd class="mt-0.5">{row.granola}</dd></div><div><dt class="text-muted-foreground">Otter</dt><dd class="mt-0.5">{row.otter}</dd></div><div><dt class="text-muted-foreground">Fireflies</dt><dd class="mt-0.5">{row.fireflies}</dd></div></dl></div>)}
			</div>
		</div>
	</Section>
</Base>
