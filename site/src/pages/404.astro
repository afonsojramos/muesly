---
import { Icon } from 'astro-icon/components';
import Button from '../components/ui/Button.astro';
import Section from '../components/ui/Section.astro';
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — muesly" description="That page doesn't exist.">
	<Section class="flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
		<p class="font-display text-6xl font-semibold text-accent">404</p>
		<h1 class="mt-4 font-display text-3xl font-semibold tracking-tight md:text-4xl">
			This page wandered off
		</h1>
		<p class="mt-3 max-w-md text-muted-foreground">
			The page you're looking for isn't here. It may have moved, or never existed. Either way, your
			meetings stay on your device.
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<Button href="/" variant="accent" size="lg">
				Back home
				<Icon name="lucide:arrow-right" class="h-4 w-4" aria-hidden="true" />
			</Button>
			<Button href="/download" variant="outline" size="lg">Download muesly</Button>
		</div>
	</Section>
</Base>
