{
	"name": "muesly-web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "node scripts/copy-privacy-policy.mjs && vite dev",
		"build": "node scripts/copy-privacy-policy.mjs && vite build",
		"preview": "vite preview",
		"prepare": "node scripts/copy-privacy-policy.mjs && svelte-kit sync || echo ''",
		"check": "node scripts/copy-privacy-policy.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"deploy": "node scripts/copy-privacy-policy.mjs && vite build && wrangler deploy"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^25.9.3",
		"@types/sanitize-html": "^2.16.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/lora": "^5.2.8",
		"@lucide/svelte": "^1.21.0",
		"clsx": "^2.1.1",
		"marked": "^18.0.5",
		"sanitize-html": "^2.17.5",
		"tailwind-merge": "^3.6.0"
	}
}
