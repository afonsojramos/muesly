{
	"name": "muesly-web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "node scripts/copy-legal-docs.mjs && astro dev",
		"build": "node scripts/copy-legal-docs.mjs && astro build",
		"preview": "astro preview",
		"sync": "node scripts/copy-legal-docs.mjs && astro sync",
		"check": "node scripts/copy-legal-docs.mjs && astro check",
		"lint": "vp lint",
		"format": "vp fmt . --write",
		"format:check": "vp fmt . --check",
		"test": "vitest run",
		"test:smoke": "nub scripts/smoke-built-site.ts",
		"deploy": "node scripts/copy-legal-docs.mjs && astro build && wrangler deploy"
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.7.3",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/lora": "^5.2.8",
		"@iconify-json/lucide": "^1.2.117",
		"astro": "^7.0.7",
		"astro-icon": "^1.1.5",
		"cnfast": "^0.0.8",
		"marked": "^18.0.6",
		"sanitize-html": "^2.17.6"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@types/sanitize-html": "^2.16.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"vite-plus": "^0.2.4",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	},
	"engines": {
		"node": "24"
	}
}
