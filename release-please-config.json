{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bootstrap-sha": "a9b5e6aeaf95661c4dbe1f24b024d6b4b8f005b0",
  "release-type": "simple",
  "skip-github-release": true,
  "include-v-in-tag": true,
  "plugins": [
    {
      "type": "sentence-case"
    }
  ],
  "packages": {
    ".": {
      "component": "muesly",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "app/src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "app/src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        },
        {
          "type": "json",
          "path": "app/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "app/src-svelte/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "Cargo.lock"
        },
        {
          "type": "generic",
          "path": "app/src-svelte/src/lib/components/About.svelte"
        }
      ]
    }
  }
}
