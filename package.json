{
	"name": "muesly-root",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm -C app tauri:dev",
		"build": "pnpm -C app tauri:build",
		"check": "pnpm -C app/src-svelte check",
		"lint": "pnpm -C app/src-svelte lint",
		"lint:fix": "pnpm -C app/src-svelte lint:fix",
		"format": "pnpm -C app/src-svelte format",
		"format:check": "pnpm -C app/src-svelte format:check",
		"test": "pnpm -C app/src-svelte test",
		"seed": "cargo run -q -p muesly --example seed-dev-data",
		"seed:clear": "cargo run -q -p muesly --example seed-dev-data -- --clear",
		"eval:wer": "node app/scripts/eval/wer.mjs",
		"eval:rubric": "node app/scripts/eval/summary-rubric.mjs",
		"eval:real": "node app/scripts/eval/real-run.mjs",
		"eval": "node app/scripts/eval/wer.mjs app/scripts/eval/fixtures/meeting-golden-ref.txt app/scripts/eval/fixtures/meeting-golden-hyp.txt --max-wer 0 && node app/scripts/eval/wer.mjs app/scripts/eval/fixtures/meeting-golden-ref.txt app/scripts/eval/fixtures/meeting-golden-hyp-noisy.txt --max-wer 10"
	}
}
