# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules/

# Rust / Cargo
target/

# Tauri (generated & bundled sidecar binaries)
app/src-tauri/gen/
app/src-tauri/binaries/

# SvelteKit / Vite (generated)
app/src-svelte/.svelte-kit/
app/src-svelte/build/
/dist
*.tsbuildinfo
vite.config.*.timestamp-*

# Models & local databases
**/models
meeting_minutes.db

# Media (recordings & demo assets)
*.wav
*.mp4
# Versioned eval audio fixture (small, license-clean) — see app/scripts/eval/README.md
!app/scripts/eval/fixtures/*.wav
# Participant recordings, verbatim references, identity-bearing consent records,
# and machine-specific benchmark artifacts must never enter the repository.
app/scripts/eval/local-corpus/
app/scripts/eval/consent-records/
app/scripts/eval/intake/
app/scripts/eval/corpus-local.json
app/scripts/eval/results/
docs/demo.mov
docs/demo.gif

# Environment & secrets
.env
.env.*
!.env.example
*.pem

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Editors & tooling
.vscode/
.idea/
.cursor/
.gstack/
.playwright-mcp/
*.sw?

# Scratch / experiments
/experiments
