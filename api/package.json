{
	"name": "muesly-api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"release": "wrangler deploy",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply muesly --remote",
		"db:migrate:local": "wrangler d1 migrations apply muesly --local",
		"typecheck": "tsc --noEmit",
		"lint": "vp lint",
		"format": "vp fmt . --write",
		"format:check": "vp fmt . --check"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260713.1",
		"drizzle-kit": "^0.31.10",
		"typescript": "^7.0.2",
		"vite-plus": "^0.2.4",
		"wrangler": "^4.110.0"
	}
}
